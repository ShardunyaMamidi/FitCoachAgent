# Copy this file to `.env` and fill in your values.
# The app reads these via os.environ (loaded by python-dotenv at startup).

# Your Google AI Studio API key (REQUIRED). Get one at aistudio.google.com/apikey.
# Must be named GOOGLE_API_KEY — this tells the google-genai SDK to use API key
# mode instead of falling back to GCP OAuth credentials.
GOOGLE_API_KEY=AIza...

# Which Gemini model to use.
#   gemini-2.0-flash  -> fast, cheap, generous free tier (recommended)
#   gemini-2.5-pro    -> most capable
MODEL_ID=gemini-2.0-flash

# Max length of a single reply (in tokens).
MAX_TOKENS=1024
