# Copy this file to `.env` and fill in your values.
# The app reads these via os.environ (loaded by python-dotenv at startup).

# Your Google Cloud project ID (REQUIRED). Find it with: gcloud config get-value project
GOOGLE_CLOUD_PROJECT=my-gcp-project-id

# Vertex AI region. "global" is recommended: best availability, no pricing premium.
VERTEX_REGION=global

# Which Claude model to use.
#   claude-haiku-4-5@20251001  -> cheapest & fastest, great for a demo
#   claude-opus-4-8            -> most capable
MODEL_ID=claude-haiku-4-5@20251001

# Max length of a single reply (in tokens). 1024 is plenty for chat answers.
MAX_TOKENS=1024
